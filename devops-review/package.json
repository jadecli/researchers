{
  "name": "@jadecli/devops-review",
  "version": "1.0.0",
  "description": "DevOps PR review engine — shared by Claude Code (agent) and Claude Cowork (skill)",
  "type": "module",
  "main": "src/orchestrator.ts",
  "scripts": {
    "review": "npx tsx src/run.ts",
    "review:code": "npx tsx src/run.ts --surface code",
    "review:cowork": "npx tsx src/run.ts --surface cowork",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0"
  }
}
