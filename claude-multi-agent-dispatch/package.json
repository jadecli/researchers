{
  "name": "claude-multi-agent-dispatch",
  "version": "0.1.0",
  "type": "module",
  "description": "Multi-agent dispatch system with structured thinking and quality scoring",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "mcp:thinking": "npx tsx src/thinking/server.ts",
    "mcp:dispatch": "npx tsx src/dispatch/mcp-server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
