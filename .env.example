# Neon Postgres 18 — required for all persistence layers
# Get your connection string from https://console.neon.tech
# Use the pooler endpoint (-pooler hostname) for serverless/HTTP access
DATABASE_URL=postgresql://user:password@ep-xxx-yyy-000.us-east-2.aws.neon.tech/neondb?sslmode=require

# Neon API key — required for GitHub Actions (branch-per-PR, schema diff)
# Generate at https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=

# Neon project ID — required for GitHub Actions
# Found in project settings: https://console.neon.tech
NEON_PROJECT_ID=

# Anthropic API key — required for Claude Code actions
ANTHROPIC_API_KEY=

# Slack integration (optional — for crawl notifications)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
