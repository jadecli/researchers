{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-setup.sh",
            "timeout": 60000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/context-pre-commit.sh",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": ".claude/hooks/context-pre-pr.sh",
            "timeout": 60000
          }
        ]
      },
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/context-pre-pr.sh",
            "timeout": 60000
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .jade/hooks/session-start.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .jade/hooks/pre-commit.sh",
            "if": "Bash(git commit*)"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-pr-intent.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/capture-prompt.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .jade/hooks/pre-pr.sh",
            "if": "Bash(gh pr create*)"
          }
        ]
      }
    ]
  }
}
